{
  "manifest_version": 3,
  "name": "Web2Markdown",
  "version": "2.0.0",
  "description": "将网页转换为 Markdown 并保存到本地，支持图片下载到同一目录",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "保存为 Markdown"
  },
  "background": {
    "service_worker": "src/background.js"
  }
}
